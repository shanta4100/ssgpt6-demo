name: CI
on: [push, pull_request]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4 # v4 is the stable standard
        with:
          node-version: 20
          cache: 'npm'
          # This will look for package-lock.json in the root

      - name: Install dependencies
        run: npm ci

      - name: Run build
        run: npm run build --if-present
